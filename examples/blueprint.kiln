<Window>
    <Blueprint id="rect-blueprint">
        <Anchor align="{align}">
            <Rectangle width-request="100" height-request="100" color="{color}"></Rectangle>
        </Anchor>
    </Blueprint>
    <Script>
        blueprint = get_blueprint("rect-blueprint")

        ALIGNS = [
            "top-left",
            "top-right",
            "bottom-left",
            "bottom-right"
        ]

        COLORS = [
            "red",
            "yellow",
            "green",
            "blue"
        ]

        for i in range(4):
            blueprint.create(align=ALIGNS[i], color=COLORS[i])
    </Script>
</Window>