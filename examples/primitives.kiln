<Window default-width="500" default-height="500" class="my-window">
    <Style>
        .my-window {
            background-color: black;
        }
    </Style>
    <Anchor anchor="top-left">
        <Rectangle width-request="100" height-request="100" color="green"></Rectangle>
    </Anchor>
    <Anchor anchor="top-right">
        <Circle radius="50" color="yellow"></Circle>
    </Anchor>
</Window>