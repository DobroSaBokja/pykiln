{
  "name": "Kiln",
  "scopeName": "text.xml.kiln",
  "fileTypes": ["kiln"],
  "patterns": [
    { "include": "#script-block" },
    { "include": "#style-block" },
    { "include": "text.xml" }
  ],
  "repository": {
    "style-block": {
      "begin": "(<)(Style)([^>]*)(>)",
      "end": "(</)(Style)(\\s*>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.xml" },
        "2": { "name": "entity.name.tag.localname.xml" },
        "3": {
          "patterns": [{ "include": "#script-tag-attributes" }]
        },
        "4": { "name": "punctuation.definition.tag.end.xml" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.xml" },
        "2": { "name": "entity.name.tag.localname.xml" },
        "3": { "name": "punctuation.definition.tag.end.xml" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        { "include": "source.css" }
      ]
    },
    "script-block": {
      "begin": "(<)(Script)([^>]*)(>)",
      "end": "(</)(Script)(\\s*>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.xml" },
        "2": { "name": "entity.name.tag.localname.xml" },
        "3": {
          "patterns": [{ "include": "#script-tag-attributes" }]
        },
        "4": { "name": "punctuation.definition.tag.end.xml" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.xml" },
        "2": { "name": "entity.name.tag.localname.xml" },
        "3": { "name": "punctuation.definition.tag.end.xml" }
      },
      "contentName": "meta.embedded.block.python",
      "patterns": [
        { "include": "#cdata-section" },
        { "include": "source.python" }
      ]
    },
    "cdata-section": {
      "begin": "<!\\[CDATA\\[",
      "end": "\\]\\]>",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.xml" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.xml" }
      },
      "patterns": [
        { "include": "source.python" }
      ]
    },
    "script-tag-attributes": {
      "patterns": [
        {
          "match": "([\\w:.-]+)(\\s*=\\s*)(\"[^\"]*\"|'[^']*')",
          "captures": {
            "1": { "name": "entity.other.attribute-name.localname.xml" },
            "2": { "name": "punctuation.separator.key-value.xml" },
            "3": { "name": "string.quoted.double.xml" }
          }
        }
      ]
    }
  }
}
